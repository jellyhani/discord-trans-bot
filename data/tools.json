  {
    "type": "function",
    "function": {
      "name": "manage_routine",
      "description": "사용자의 정기 작업(루틴)을 관리합니다. (예: 매일 아침 8시에 날씨 알려줘)",
      "parameters": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["add", "remove", "list"],
            "description": "수행할 작업"
          },
          "task_type": {
            "type": "string",
            "enum": ["search", "weather", "news"],
            "description": "루틴 종류"
          },
          "query": {
            "type": "string",
            "description": "검색어 또는 지역명"
          },
          "schedule_time": {
            "type": "string",
            "description": "시간 (HH:MM) 24시간제"
          },
          "routine_id": {
            "type": "integer",
            "description": "삭제 시 필요한 루틴 ID"
          },
          "destination": {
            "type": "string",
            "enum": ["channel", "dm"],
            "description": "결과 전송 위치",
            "default": "channel"
          }
        },
        "required": ["action"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "execute_delayed_task",
      "description": "일정 시간 후 메시지 전송 또는 작업 실행. ('channel' 전송 시에만 관리자 권한 필요). 상대적인 시간(1시간 뒤 등)을 초 단위로 변환하여 입력하세요.",
      "parameters": {
        "type": "object",
        "properties": {
          "delay_seconds": {
            "type": "integer",
            "description": "지연 시간(초). 예: 1시간=3600"
          },
          "content": {
            "type": "string",
            "description": "전송할 구체적인 메시지 내용"
          },
          "repeat_count": {
            "type": "integer",
            "description": "총 반복 횟수 (최대 10회 권장)",
            "default": 1
          },
          "interval_seconds": {
            "type": "integer",
            "description": "반복 사이의 간격(초)",
            "default": 0
          },
          "destination": {
            "type": "string",
            "enum": ["channel", "dm"],
            "default": "channel"
          }
        },
        "required": ["delay_seconds", "content"]
      }
    }
  },
